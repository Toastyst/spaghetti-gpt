# Copy this file to .env.local and fill values before running locally.
# Do NOT commit your real API keys.

# Primary provider (example): OpenRouter
OPENROUTER_API_KEY=

# Alternate common providers
OPENAI_API_KEY=
AZURE_OPENAI_KEY=
HUGGINGFACE_API_KEY=

# ElevenLabs TTS (high quality natural voices - recommended for storytelling)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: default model to use (override per request if supported)
# MODEL=gpt-4o-mini

# Feature flags
# Enable Vercel AI Gateway in your project dashboard (Settings > AI) for unified
# model routing, cost tracking, failover, Perplexity web search tools, etc.
# No direct provider keys needed on Vercel (uses OIDC). For local dev run:
#   vercel env pull .env.local
VERCEL_AI_GATEWAY_ENABLED=false

# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# AI Gateway API key (only needed if not using OIDC / vercel env pull)
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
