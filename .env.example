# Copy this file to .env.local and fill values before running locally.
# Do NOT commit your real API keys.

# Primary provider (example): OpenRouter
OPENROUTER_API_KEY=

# Alternate common providers
OPENAI_API_KEY=
AZURE_OPENAI_KEY=
HUGGINGFACE_API_KEY=

# Optional: default model to use (override per request if supported)
# MODEL=gpt-4o-mini

# Feature flags
# If you deploy to Vercel and want to use Vercel AI Gateway, enable it in
# your Vercel project settings instead of setting a provider key here.
VERCEL_AI_GATEWAY_ENABLED=false
# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
